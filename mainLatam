-- Función Toggle (Cambia a Verde)
local function AddOption(name, func)
    local btn = Instance.new("TextButton")
    btn.Parent = MainFrame
    btn.Size = UDim2.new(0.9, 0, 0, 38)
    btn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(180, 0, 0)
        func(active)
    end)
end

-- --- OPCIONES ACTUALIZADAS ---

-- 1. SPEED BOOSTER (X que pediste)
AddOption("Speed Booster", function(active)
    _G.Speed = active
    spawn(function()
        while _G.Speed do
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 80 -- Velocidad God
            wait(0.1)
        end
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16 -- Velocidad Normal
    end)
end)

-- 2. TP BASE (Detección Inteligente)
AddOption("Tp Base", function(active)
    if active then
        local player = game.Players.LocalPlayer
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        -- Busca el Spawn real del juego
        local spawnPos = workspace:FindFirstChildOfClass("SpawnLocation")
        if hrp then
            if spawnPos then
                hrp.CFrame = spawnPos.CFrame + Vector3.new(0, 5, 0)
            else
                -- Coordenada de emergencia si no hay spawn
                hrp.CFrame = CFrame.new(0, 100, 0) 
            end
        end
    end
end)

-- 3. GOD MODE (Reforzado)
AddOption("God Mode", function(state)
    _G.God = state
    spawn(function()
        while _G.God do
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.Health = char.Humanoid.MaxHealth
                if char:FindFirstChild("Health") then char.Health.Disabled = true end
            end
            wait(0.1)
        end
    end)
end)

-- 4. INFINITE JUMP
AddOption("Infinite Jump", function(s)
    _G.Jump = s
    game:GetService("UserInputService").JumpRequest:Connect(function()
        if _G.Jump then game.Players.LocalPlayer.Character.Humanoid:ChangeState("Jumping") end
    end)
end)

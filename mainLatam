-- Botón Cerrar (X) y Minimizar (-)
local function CreateControl(txt, pos, color, func)
    local b = Instance.new("TextButton")
    b.Parent = MainFrame
    b.Size = UDim2.new(0, 25, 0, 20)
    b.Position = pos
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.MouseButton1Click:Connect(func)
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
end

CreateControl("X", UDim2.new(0.5, -12, 0, 5), Color3.fromRGB(200, 0, 0), function() ScreenGui:Destroy() end)
CreateControl("-", UDim2.new(0.5, -12, 0, 28), Color3.fromRGB(50, 50, 50), function()
    MainFrame.ClipsDescendants = true
    MainFrame.Size = (MainFrame.Size.Y.Offset > 50) and UDim2.new(0, 160, 0, 50) or UDim2.new(0, 160, 0, 300)
end)


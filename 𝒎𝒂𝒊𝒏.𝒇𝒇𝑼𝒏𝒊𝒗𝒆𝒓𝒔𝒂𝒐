-- 3. FUNCIONES (SILENT AIM & HOLOGRAMA)
_G.Silent = false; _G.Holo = false

task.spawn(function()
    while task.wait(0.5) do
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= LP and p.Character then
                -- Hitbox (Silent Aim)
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then root.Size = _G.Silent and Vector3.new(18,18,18) or Vector3.new(2,2,1); root.Transparency = 1 end
                
                -- Holograma Cyan (ESP)
                local h = p.Character:FindFirstChild("AHolo")
                if _G.Holo then
                    if not h then 
                        h = Instance.new("Highlight", p.Character); h.Name = "AHolo"
                        h.FillColor = Color3.fromRGB(0,255,255); h.FillTransparency = 0.5
                    end
                elseif h then h:Destroy() end
            end
        end
    end
end)


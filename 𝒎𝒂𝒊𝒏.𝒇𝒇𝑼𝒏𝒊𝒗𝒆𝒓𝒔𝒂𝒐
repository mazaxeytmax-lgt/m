local function AddSwitch(name, var)
    local btn = Instance.new("TextButton", Container)
    btn.Size = UDim2.new(1, 0, 0, 35); btn.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    btn.Text = "  " .. name; btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Font = "Gotham"; btn.TextXAlignment = "Left"
    btn.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        btn.TextColor3 = _G[var] and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 255, 255)
    end)
    Instance.new("UICorner", btn)
end

AddSwitch("Silent Aim (Hitbox)", "Silent")

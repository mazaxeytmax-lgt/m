-- Botones de Control
local function CreateControl(txt, pos, color, func)
    local b = Instance.new("TextButton", TopBar)
    b.Size = UDim2.new(0, 35, 0, 30)
    b.Position = pos
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
end

CreateControl("X", UDim2.new(1, -45, 0, 15), Color3.fromRGB(200, 0, 0), function() ScreenGui:Destroy() end)
local min = false
CreateControl("-", UDim2.new(1, -90, 0, 15), Color3.fromRGB(60, 60, 60), function()
    min = not min
    Container.Visible = not min
    MainFrame.Size = min and UDim2.new(0, 270, 0, 60) or UDim2.new(0, 270, 0, 420)
end)


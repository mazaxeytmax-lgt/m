-- Función Botón Toggle
local function AddOption(name, func)
    local btn = Instance.new("TextButton", Container)
    btn.Size = UDim2.new(0.9, 0, 0, 55)
    btn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 18
    Instance.new("UICorner", btn)

    local act = false
    btn.MouseButton1Click:Connect(function()
        act = not act
        btn.BackgroundColor3 = act and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        func(act)
    end)
end

-- --- OPCIONES ---

-- 1. SPEED BOOSTER (CON AUTO-REAPARICIÓN)
AddOption("Speed Booster", function(state)
    _G.Spd = state
    task.spawn(function()
        while true do
            if not _G.Spd then break end
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = 80
            end
            task.wait(0.5) -- Revisa cada medio segundo si reviviste para ponerte Speed
        end
        if game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
        end
    end)
end)

-- 2. ANTI-LAVA / HAZARDS
AddOption("Anti-Lava / Hazards", function(state)
    _G.AntiLava = state
    task.spawn(function()
        while _G.AntiLava do
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name:lower():find("lava") or v.Name:lower():find("water") or v.Name:lower():find("kill")) then
                    v.CanTouch = false
                end
            end
            task.wait(2)
        end
    end)
end)

-- 3. GOD MODE
AddOption("God Mode", function(state)
    _G.God = state
    task.spawn(function()
        while _G.God do
            pcall(function() game.Players.LocalPlayer.Character.Humanoid.Health = 100 end)
            task.wait(0.1)
        end
    end)
end)

-- 4. TP BASE
AddOption("Tp Base", function(state)
    if state then
        local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(0, 20, 0) end
    end
end)

-- 5. JUMP INFINITO
AddOption("Infinite Jump", function(s)
    _G.Jump = s
    game:GetService("UserInputService").JumpRequest:Connect(function()
        if _G.Jump then game.Players.LocalPlayer.Character.Humanoid:ChangeState("Jumping") end
    end)
end)

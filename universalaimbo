-- // 2. LÓGICA ESP (3-en-1 con Skeleton)
local function GetSkeletonJoints(char)
    local parts = {
        {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"},
        {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"},
        {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"},
        {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}
    }
    return parts
end

local function CreateESP(p)
    local Box = Drawing.new("Square")
    Box.Filled, Box.Color, Box.Transparency = true, Color3.new(1, 1, 1), 0.3
    local Tracer = Drawing.new("Line")
    Tracer.Color = Color3.new(1, 1, 1)
    
    local skelLines = {}
    for i=1, 10 do skelLines[i] = Drawing.new("Line") skelLines[i].Color = Color3.new(1,1,1) end

    RunService.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and Config.ESP and p ~= LocalPlayer then
            local Root = p.Character.HumanoidRootPart
            local Pos, On = Camera:WorldToViewportPoint(Root.Position)
            if On then
                Box.Visible = true
                Box.Size = Vector2.new(1300/Pos.Z, 1800/Pos.Z)
                Box.Position = Vector2.new(Pos.X - Box.Size.X/2, Pos.Y - Box.Size.Y/2)
                Tracer.Visible, Tracer.From, Tracer.To = true, Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2), Vector2.new(Pos.X, Pos.Y)
                
                local joints = GetSkeletonJoints(p.Character)
                for i, j in pairs(joints) do
                    local p1, p2 = p.Character:FindFirstChild(j[1]), p.Character:FindFirstChild(j[2])
                    if p1 and p2 then
                        local v1, o1 = Camera:WorldToViewportPoint(p1.Position)
                        local v2, o2 = Camera:WorldToViewportPoint(p2.Position)
                        if o1 and o2 then
                            skelLines[i].Visible, skelLines[i].From, skelLines[i].To = true, Vector2.new(v1.X, v1.Y), Vector2.new(v2.X, v2.Y)
                        else skelLines[i].Visible = false end
                    end
                end
            else 
                Box.Visible, Tracer.Visible = false, false
                for _,l in pairs(skelLines) do l.Visible = false end
            end
        else 
            Box.Visible, Tracer.Visible = false, false
            for _,l in pairs(skelLines) do l.Visible = false end
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- // 3. FOV Y AIMBOT
local FOVCircle = Drawing.new("Circle")
FOVCircle.Color, FOVCircle.Thickness, FOVCircle.Filled = Color3.new(1,1,1), 1.5, false

RunService.RenderStepped:Connect(function()
    FOVCircle.Visible, FOVCircle.Radius = Config.FOV_Visible, Config.FOV_Radius
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    if Config.Aimbot then
        local target, dist = nil, Config.FOV_Radius
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and p.Character.Humanoid.Health > 0 then
                local P, On = Camera:WorldToViewportPoint(p.Character.Head.Position)
                if On then
                    local MDist = (Vector2.new(P.X, P.Y) - FOVCircle.Position).Magnitude
                    if MDist < dist then dist = MDist target = p.Character.Head end
                end
            end
        end
        if target then
            -- Lógica Smooth: Cuanto menor el número en el cuadro, más fuerte apunta
            local lerpVal = 1 / (Config.Smoothness or 10)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), lerpVal)
        end
    end
end)

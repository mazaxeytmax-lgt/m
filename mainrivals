-- LÓGICA DE AIM LOCK (OPTIMIZADA)
local function getClosestPlayer()
    local closest = nil
    local dist = math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Head") then
            local pos, onScreen = camera:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if mag < dist then
                    closest = v.Character.Head
                    dist = mag
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if Config.AimLock then
        local target = getClosestPlayer()
        if target then
            camera.CFrame = CFrame.new(camera.CFrame.Position, target.Position)
        end
    end
end)

-- LÓGICA ESP (HIGHLIGHTS)
RunService.Heartbeat:Connect(function()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character then
            local highlight = v.Character:FindFirstChild("MazAxe_ESP")
            if Config.ESP then
                if not highlight then
                    highlight = Instance.new("Highlight", v.Character)
                    highlight.Name = "MazAxe_ESP"
                end
                highlight.FillColor = Color3.fromRGB(200, 0, 0)
                highlight.OutlineColor = Color3.new(1, 1, 1)
            else
                if highlight then highlight:Destroy() end
            end
        end
    end
end)

-- CREADOR DE BOTONES
local function addToggle(txt, y, conf)
    local b = Instance.new("TextButton", frame)
    b.Size = UDim2.new(0.85, 0, 0, 40)
    b.Position = UDim2.new(0.075, 0, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = txt .. ": OFF"
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamSemibold
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    
    b.MouseButton1Click:Connect(function()
        Config[conf] = not Config[conf]
        b.Text = txt .. ": " .. (Config[conf] and "ON" or "OFF")
        b.BackgroundColor3 = Config[conf] and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(25, 25, 25)
    end)
end

addToggle("AIM LOCK", 60, "AimLock")
